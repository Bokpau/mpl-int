# Backend proxy (shared with the PH site). Server-side ONLY — never expose to the browser.
# Point at the deployed Render backend, or http://localhost:PORT when running it locally.
BACKEND_URL=https://mpl-ph-s17-backend.onrender.com

# The shared internal API key the backend's requireApiKey middleware checks (x-api-key).
# Server-side ONLY (no NEXT_PUBLIC_ prefix) so it never reaches the client bundle.
INTERNAL_API_KEY=replace-with-the-backend-INTERNAL_API_KEY
